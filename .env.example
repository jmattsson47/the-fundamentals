# linq labs — auth gate environment variables
# Set the REAL values in Vercel → Project → Settings → Environment Variables.
# Never commit a filled-in .env (see .gitignore).

# Google OAuth 2.0 Web client (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random 32+ byte secret used to sign the session cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# Google Workspace domain allowed to sign in.
ALLOWED_HD=linqapp.com
